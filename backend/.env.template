# Database
DATABASE_URL=postgres://medusa:medusa@localhost:5432/meduso

# Redis (optional for local dev, required for production multi-instance)
REDIS_URL=redis://localhost:6379

# CORS
STORE_CORS=http://localhost:8000
ADMIN_CORS=http://localhost:9000
AUTH_CORS=http://localhost:8000,http://localhost:9000

# Secrets (change in production!)
JWT_SECRET=supersecret
COOKIE_SECRET=supersecret

# Worker mode: "shared" (default), "server", or "worker"
# MEDUSA_WORKER_MODE=shared

# Disable admin dashboard (useful for worker instances)
# DISABLE_MEDUSA_ADMIN=true
